{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bruh.local/schemas/shared-personas.schema.json",
  "title": "Shared Personas Catalog",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "id",
      "displayName",
      "avatarName",
      "handle",
      "domains",
      "leadInterestIds",
      "stance",
      "triggerKeywords",
      "entityKeywords",
      "subtitle",
      "inviteMessage",
      "themeColorHex",
      "locationLabel",
      "baseInviteOrder",
      "primaryLanguage",
      "friendGreeting",
      "aliases",
      "platformAccounts",
      "defaultVoiceSpeakerId",
      "defaultVoiceLabel",
      "socialCircleIds",
      "relationshipHints"
    ],
    "properties": {
      "id": {
        "type": "string",
        "minLength": 1
      },
      "displayName": {
        "type": "string",
        "minLength": 1
      },
      "avatarName": {
        "type": "string",
        "minLength": 1
      },
      "handle": {
        "type": "string",
        "minLength": 2
      },
      "domains": {
        "type": "array",
        "items": {
          "type": "string",
          "minLength": 1
        }
      },
      "leadInterestIds": {
        "type": "array",
        "items": {
          "type": "string",
          "minLength": 1
        }
      },
      "stance": {
        "type": "string",
        "minLength": 1
      },
      "triggerKeywords": {
        "type": "array",
        "items": {
          "type": "string",
          "minLength": 1
        }
      },
      "entityKeywords": {
        "type": "array",
        "items": {
          "type": "string",
          "minLength": 1
        }
      },
      "subtitle": {
        "type": "string",
        "minLength": 1
      },
      "inviteMessage": {
        "type": "string",
        "minLength": 1
      },
      "themeColorHex": {
        "type": "string",
        "pattern": "^#[0-9A-Fa-f]{6}$"
      },
      "locationLabel": {
        "type": "string",
        "minLength": 1
      },
      "baseInviteOrder": {
        "type": "integer",
        "minimum": 0
      },
      "primaryLanguage": {
        "type": "string",
        "enum": ["en", "zh"]
      },
      "friendGreeting": {
        "type": "string",
        "minLength": 1
      },
      "aliases": {
        "type": "array",
        "items": {
          "type": "string",
          "minLength": 1
        }
      },
      "platformAccounts": {
        "type": "array",
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": ["platform", "handle", "profileUrl", "isPrimary", "isActive"],
          "properties": {
            "platform": {
              "type": "string",
              "minLength": 1
            },
            "handle": {
              "type": "string",
              "minLength": 1
            },
            "profileUrl": {
              "type": ["string", "null"]
            },
            "isPrimary": {
              "type": "boolean"
            },
            "isActive": {
              "type": "boolean"
            }
          }
        }
      },
      "defaultVoiceSpeakerId": {
        "type": "string",
        "minLength": 1
      },
      "defaultVoiceLabel": {
        "type": "string",
        "minLength": 1
      },
      "socialCircleIds": {
        "type": "array",
        "items": {
          "type": "string",
          "minLength": 1
        }
      },
      "relationshipHints": {
        "type": "object",
        "additionalProperties": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
